<h1>histories</h1>

<h1>this is the history id <%= @history.id %></h1>
<h1>this is the history stock id <%= @history.stock_id %></h1>
<h1>this is the stock id <%= @stock.id %></h1>


<% @histories.each do |h| %>
  <div class="history">
  <%= h.stock_id %>
  <%= h.price %>
  <%= h.date %>
  </div>
<% end %>
