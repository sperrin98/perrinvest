<div class="container">
  <h1><%= @blog.title %></h1>
  <div class="form-container">
    <%= simple_form_for @blog, html: { class: "form-new"} do |f| %>
        <%= f.input :title, placeholder: 'Title...' %>
        <%= f.input :subtitle, placeholder: 'A small introduction...' %>
        <%= f.input :content, placeholder: 'Your blog content...' %>
        <%= f.label :image_url %>
        <%= f.file_field  :image_url %>
        <%# <%= f.input :publisher, placeholder: 'Publisher...' %>
        <%= f.button :submit, class: "button-form" %>
      <% end %>
  </div>
</div>
