<div class="container">
  <h2 class="stock-title">Stocks</h2>
  <div class="card-container">
    <% @stocks.each do |stock| %>
      <ul class="cards">
        <h4 class="card-text"><%= stock.name %></h4>
        <%= image_tag("#{stock.image_url}", class: "stock-img-card img-thumbnail") %>
      </ul>
    <% end %>
  </div>
</div>
